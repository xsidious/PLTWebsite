# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where bid request emails are delivered
BID_TO_EMAIL=your-email@example.com

# Where job application emails are delivered (falls back to BID_TO_EMAIL if unset)
CAREERS_TO_EMAIL=your-email@example.com

# Verified sender domain in Resend (must match your verified domain)
BID_FROM_EMAIL=PDT Unlimited <bids@yourdomain.com>
