# Resend API key — get one at https://resend.com (set in Vercel, never commit real keys)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where bid + career emails are delivered
BID_TO_EMAIL=Pdtunlimited@gmail.com
CAREERS_TO_EMAIL=Pdtunlimited@gmail.com

# Sender address — use onboarding@resend.dev until you verify a custom domain in Resend
BID_FROM_EMAIL=PDT Unlimited <onboarding@resend.dev>

# Public site URL (used for sitemap, canonical, Open Graph)
NEXT_PUBLIC_SITE_URL=https://pdtunlimited.com

# Google Search Console verification token (content value only)
# GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Bing Webmaster Tools verification (optional)
# BING_SITE_VERIFICATION=your-bing-verification-code
